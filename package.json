@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap');
@tailwind base;
@tailwind components;
@tailwind utilities;

/* ─── Pastel palette tokens ───
   Rose pastel : #F2A7C3  (soft warm pink)
   Violet pastel: #C3A7E8  (soft lavender violet)
   Accent mid  : #D9A0DA  (rose-violet blend)
   Background  : #0D0B12  (deep soft dark, hint of violet)
──────────────────────────────── */

@layer base {
  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    background-color: #0D0B12;
    color: #ffffff;
    font-family: 'Inter', system-ui, sans-serif;
    overflow-x: hidden;
    margin: 0;
  }

  #root {
    width: 100%;
    max-width: 100%;
    text-align: left;
    border: none;
    min-height: 100svh;
    display: block;
  }

  ::selection {
    background: rgba(195, 167, 232, 0.35);
    color: #fff;
  }

  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: #0D0B12; }
  ::-webkit-scrollbar-thumb {
    background: linear-gradient(to bottom, #F2A7C3, #C3A7E8);
    border-radius: 3px;
  }
}

@layer utilities {
  /* Text gradient: pastel rose → pastel violet */
  .text-gradient {
    background: linear-gradient(135deg, #F2A7C3 0%, #D9A0DA 50%, #C3A7E8 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .bg-glass {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.07);
  }

  /* Pastel rose-violet tinted glass */
  .bg-glass-pink {
    background: rgba(242, 167, 195, 0.06);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(242, 167, 195, 0.18);
  }

  .glow-pink {
    box-shadow: 0 0 60px rgba(195, 167, 232, 0.18), 0 0 120px rgba(242, 167, 195, 0.08);
  }

  .card-hover {
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .card-hover:hover {
    transform: translateY(-8px);
    box-shadow: 0 30px 60px rgba(195, 167, 232, 0.16), 0 0 0 1px rgba(242, 167, 195, 0.18);
  }

  /* Primary button: pastel rose → pastel violet */
  .btn-primary {
    position: relative;
    overflow: hidden;
    padding: 14px 36px;
    border-radius: 9999px;
    font-weight: 600;
    color: #1a0d22;
    transition: all 0.3s ease;
    background: linear-gradient(135deg, #F2A7C3, #C3A7E8);
    box-shadow: 0 4px 30px rgba(195, 167, 232, 0.35);
    display: inline-block;
    cursor: pointer;
    border: none;
    font-size: 15px;
    letter-spacing: 0.3px;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 40px rgba(195, 167, 232, 0.55);
  }

  /* Outline button */
  .btn-outline {
    position: relative;
    overflow: hidden;
    padding: 13px 36px;
    border-radius: 9999px;
    font-weight: 600;
    transition: all 0.3s ease;
    background: transparent;
    border: 1px solid rgba(195, 167, 232, 0.5);
    color: #D9A0DA;
    display: inline-block;
    cursor: pointer;
    font-size: 15px;
    letter-spacing: 0.3px;
  }
  .btn-outline:hover {
    background: rgba(195, 167, 232, 0.1);
    border-color: #C3A7E8;
    transform: translateY(-2px);
  }

  .section-padding {
    padding-top: 96px;
    padding-bottom: 96px;
    padding-left: 24px;
    padding-right: 24px;
  }
  @media (min-width: 768px) {
    .section-padding { padding-left: 48px; padding-right: 48px; }
  }
  @media (min-width: 1024px) {
    .section-padding { padding-left: 80px; padding-right: 80px; }
  }
}

/* Hero background: pastel rose + violet orbs */
.hero-bg {
  background:
    radial-gradient(ellipse at 15% 50%, rgba(242, 167, 195, 0.12) 0%, transparent 55%),
    radial-gradient(ellipse at 85% 20%, rgba(195, 167, 232, 0.10) 0%, transparent 50%),
    radial-gradient(ellipse at 50% 90%, rgba(217, 160, 218, 0.07) 0%, transparent 50%),
    #0D0B12;
}

.orb {
  border-radius: 50%;
  filter: blur(90px);
  animation: float 8s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50%       { transform: translateY(-24px); }
}

@keyframes fadeUp {
  0%   { opacity: 0; transform: translateY(30px); }
  100% { opacity: 1; transform: translateY(0); }
}

@keyframes scaleIn {
  0%   { opacity: 0; transform: scale(0.92); }
  100% { opacity: 1; transform: scale(1); }
}

.animate-fade-up   { animation: fadeUp 0.7s ease-out forwards; }
.animate-scale-in  { animation: scaleIn 0.6s ease-out forwards; }

.delay-100 { animation-delay: 0.1s; }
.delay-200 { animation-delay: 0.2s; }
.delay-300 { animation-delay: 0.3s; }
.delay-400 { animation-delay: 0.4s; }
.delay-500 { animation-delay: 0.5s; }

.animate-on-scroll {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.7s ease-out, transform 0.7s ease-out;
}
.animate-on-scroll.visible {
  opacity: 1;
  transform: translateY(0);
}
